# Copy to .env (gitignored) and fill in. Reaches remote Linux boxes (droplet /
# Pi) for the capabilities macOS lacks (UFFD, Firecracker, vsock). NEVER commit.
#
# `scripts/host.sh <a|b> <cmd>` maps these REMOTE_<A|B>_* blocks onto the generic
# R* vars that scripts/remote.sh reads; remote.sh itself is host-agnostic (give
# it RHOST/RUSER/RPORT/RPATH and RKEY or RPASS and it just works).

# host A (default; `scripts/remote.sh <cmd>` / `just remote-*`)
REMOTE_A_HOST=          # droplet IP or hostname, e.g. 203.0.113.7
REMOTE_A_USER=root
REMOTE_A_PORT=22
REMOTE_A_PATH=sleepwalk # destination dir under the remote user's home

# auth — fill ONE
# Key strongly preferred. Password support needs `sshpass` installed locally and
# is the weaker option (after first login, run `ssh-copy-id` and switch to a key).
REMOTE_A_SSH_KEY=       # path to private key, e.g. ~/.ssh/id_ed25519
REMOTE_A_PASSWORD=      # OR a password (leave KEY blank if you use this)

# host B (migration target; `scripts/remote.sh --host b <cmd>`)
# The second droplet for A->B migration. Same size/region as host A (CPU
# homogeneity — restore fails on a CPUID mismatch).
REMOTE_B_HOST=
REMOTE_B_USER=root
REMOTE_B_PORT=22
REMOTE_B_PATH=sleepwalk
REMOTE_B_SSH_KEY=
REMOTE_B_PASSWORD=

# agent demo secret
# The coding-agent demo (scripts/start-agent.sh) needs a model API key. hostd
# hands it to the guest at boot over the Secrets vsock message — never baked into
# the rootfs or kernel cmdline. A free Groq key works (console.groq.com). Use a
# dedicated, spend-limited, revocable key; the synthetic demo (prepare.sh) needs none.
AGENT_API_KEY=          # e.g. gsk_... (free Groq key)
# AGENT_MODEL=groq/llama-3.3-70b-versatile   # optional; this is the default
