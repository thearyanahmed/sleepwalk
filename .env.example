# Copy to .env (gitignored) and fill in. Used by scripts/remote.sh and the
# `remote-*` just targets to reach a remote Linux box (droplet / Pi) for the
# capabilities macOS lacks (UFFD, Firecracker, vsock). NEVER commit .env.

# --- host A (default; `scripts/remote.sh <cmd>` / `just remote-*`) ---
REMOTE_HOST=            # droplet IP or hostname, e.g. 203.0.113.7
REMOTE_USER=root
REMOTE_PORT=22
REMOTE_PATH=sleepwalk   # destination dir under the remote user's home

# auth — fill ONE
# Key strongly preferred. Password support needs `sshpass` installed locally and
# is the weaker option (after first login, run `ssh-copy-id` and switch to a key).
REMOTE_SSH_KEY=         # path to private key, e.g. ~/.ssh/id_ed25519
REMOTE_PASSWORD=        # OR a password (leave KEY blank if you use this)

# --- host B (migration target; `scripts/remote.sh --host b <cmd>`) ---
# The second droplet for A->B migration. Same size/region as host A (CPU
# homogeneity — restore fails on a CPUID mismatch).
REMOTE_B_HOST=
REMOTE_B_USER=root
REMOTE_B_PORT=22
REMOTE_B_PATH=sleepwalk
REMOTE_B_SSH_KEY=
REMOTE_B_PASSWORD=

# remote runtime secret (set on the remote's OWN .env, not synced from here)
# The remote's hostd reads ANTHROPIC_API_KEY from its own .env. Use a dedicated,
# spend-limited, revocable key; never put the real key in your local file.
# ANTHROPIC_API_KEY=
