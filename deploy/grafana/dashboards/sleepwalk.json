{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "sleepwalk — migrations",
  "uid": "sleepwalk-migrations",
  "tags": ["sleepwalk"],
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "stat",
      "title": "Migrations completed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(sleepwalk_migrations_total)" }
      ]
    },
    {
      "type": "stat",
      "title": "Migration failures",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(sleepwalk_migration_failures_total)" }
      ]
    },
    {
      "type": "stat",
      "title": "Bytes moved (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(sleepwalk_snapshot_bytes_total)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Migration rate (per second)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(sleepwalk_migrations_total[1m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Freeze window (source cost) — p50 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "always" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sleepwalk_freeze_window_seconds{quantile=\"0.5\"}", "legendFormat": "p50 {{instance}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sleepwalk_freeze_window_seconds{quantile=\"0.99\"}", "legendFormat": "p99 {{instance}}" }
      ]
    }
  ]
}
