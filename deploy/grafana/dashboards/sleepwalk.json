{
  "annotations": {
    "list": [
      {
        "name": "migrations",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "enable": true,
        "iconColor": "red",
        "expr": "changes(sum(sleepwalk_migrations_total)[2m:10s]) > 0",
        "step": "10s",
        "titleFormat": "migration"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "title": "sleepwalk — fleet, VMs & load",
  "uid": "sleepwalk-fleet",
  "tags": ["sleepwalk"],
  "timezone": "browser",
  "time": { "from": "now-30m", "to": "now" },
  "refresh": "5s",
  "schemaVersion": 39,
  "panels": [
    {
      "type": "row",
      "title": "Fleet — hosts & machine resources",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "table",
      "title": "Servers (by IP, up/down)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 },
      "description": "node_exporter targets: host label, instance (ip:port), and whether the scrape is up.",
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "up", "color": "green", "index": 0 }, "0": { "text": "down", "color": "red", "index": 1 } } }
          ]
        },
        "overrides": []
      },
      "options": { "showHeader": true },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "up{job=\"node\"}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "job": true, "__name__": true }, "renameByName": { "host": "host", "instance": "ip:port", "Value": "up" } } }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU busy % (by host)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)", "legendFormat": "{{host}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Memory used % (by host)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 15 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)", "legendFormat": "{{host}}" }
      ]
    },
    {
      "type": "row",
      "title": "VMs — placement (where each firecracker runs)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }
    },
    {
      "type": "table",
      "title": "VM placement (vm_id → host / ip)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 9 },
      "description": "Only VMs present right now (sleepwalk_vm_info == 1). On a migration the same vm_id's host/ip flips — watch the row change.",
      "fieldConfig": { "defaults": { "custom": { "align": "auto", "filterable": true } }, "overrides": [] },
      "options": { "showHeader": true },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sleepwalk_vm_info == 1", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "job": true, "instance": true, "__name__": true, "Value": true }, "renameByName": { "vm_id": "vm_id", "host": "host", "ip": "ip" } } }
      ]
    },
    {
      "type": "timeseries",
      "title": "VMs per host",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 9 },
      "description": "Count of present VMs per host — the lines cross over when a migration moves one across.",
      "fieldConfig": { "defaults": { "unit": "short", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 20, "lineInterpolation": "stepAfter" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count by (host) (sleepwalk_vm_info == 1)", "legendFormat": "{{host}}" }
      ]
    },
    {
      "type": "row",
      "title": "Load & migrations — RPS holds through the move",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 }
    },
    {
      "type": "timeseries",
      "title": "Request rate (ok turns/s, by vm)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "description": "Load-generator throughput per VM. The migration annotation marks the freeze; the line should barely dip across it.",
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (vm_id) (rate(sleepwalk_test_turns_total{outcome=\"ok\"}[1m]))", "legendFormat": "{{vm_id}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Dropped turns/s (by vm)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "description": "Turns with no completion in the deadline — spikes by exactly the turns lost to a freeze.",
      "fieldConfig": { "defaults": { "unit": "reqps", "min": 0, "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "auto" }, "color": { "mode": "fixed", "fixedColor": "red" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (vm_id) (rate(sleepwalk_test_turns_total{outcome=\"dropped\"}[1m]))", "legendFormat": "{{vm_id}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Migrations completed",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 26 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(sleepwalk_migrations_total)" }
      ]
    },
    {
      "type": "stat",
      "title": "Migration failures",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 26 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(sleepwalk_migration_failures_total)" }
      ]
    },
    {
      "type": "stat",
      "title": "Bytes moved (total)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "thresholds" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(sleepwalk_snapshot_bytes_total)" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Migration rate (/s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 26 },
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(rate(sleepwalk_migrations_total[1m]))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Freeze window (source cost) — p50 / p99",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "always" } }, "overrides": [] },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sleepwalk_freeze_window_seconds{quantile=\"0.5\"}", "legendFormat": "p50 {{instance}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sleepwalk_freeze_window_seconds{quantile=\"0.99\"}", "legendFormat": "p99 {{instance}}" }
      ]
    }
  ]
}
